# ── Banco ──────────────────────────────────────────────
DATABASE_URL=postgresql://e1puser:e1ppass@localhost:5432/e1pdb

# ── IA (Anthropic) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=gere-uma-string-aleatoria-longa-aqui
JWT_EXPIRE_MINUTES=10080
SESSION_IDLE_TIMEOUT_MINUTES=30

# ── Super Admin (Master) — semeado no start ────────────
SUPER_ADMIN_EMAIL=admin@e1p.com
SUPER_ADMIN_PASSWORD=troque-esta-senha
SUPER_ADMIN_NAME=Administrador e1p

# ── App ────────────────────────────────────────────────
ENVIRONMENT=development
ROOT_DOMAIN=e1p.com
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated

# ── Integrações (preencher quando cada módulo for ativado) ──
# WhatsApp Cloud API (Meta) — vazio = notificações viram log (graceful degradation)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=

# ── E-mail transacional (SMTP genérico — cobre também o endpoint SMTP do Amazon SES) ──
# SMTP_HOST vazio = e-mail vira log (dev). Preencher para entrega real (recuperação de senha / convite).
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=nao-responder@e1p.com
# SMTP_USE_TLS=true

# ── Gateway de pagamento real (Asaas) — vazio = mantém o stub (graceful degradation) ──
# Preencha a chave para gerar boleto/Pix REGISTRADO e receber o webhook real. base_url vazio
# usa o default do provedor; aponte para o sandbox ao testar. GATEWAY_WEBHOOK_SECRET valida a
# origem do webhook (header do provedor); vazio = webhook aberto (só dev/teste).
# PAYMENT_GATEWAY_PROVIDER=asaas
# PAYMENT_GATEWAY_API_KEY=
# PAYMENT_GATEWAY_BASE_URL=https://api-sandbox.asaas.com/v3
# GATEWAY_WEBHOOK_SECRET=

# ── Google (Meet/Calendar OAuth) — app OAuth GLOBAL da plataforma ──
# Vazio = integração indisponível (a Agenda segue com o campo manual de reunião).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://api.<dominio>/integrations/google/callback
