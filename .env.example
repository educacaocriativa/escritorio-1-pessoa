# ── Banco ──────────────────────────────────────────────
DATABASE_URL=postgresql://e1puser:e1ppass@localhost:5432/e1pdb

# ── IA (Anthropic) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=gere-uma-string-aleatoria-longa-aqui
JWT_EXPIRE_MINUTES=10080
SESSION_IDLE_TIMEOUT_MINUTES=30

# ── Super Admin (Master) — semeado no start ────────────
SUPER_ADMIN_EMAIL=admin@e1p.com
SUPER_ADMIN_PASSWORD=troque-esta-senha
SUPER_ADMIN_NAME=Administrador e1p

# ── App ────────────────────────────────────────────────
ENVIRONMENT=development
ROOT_DOMAIN=e1p.com
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated

# ── Integrações (preencher quando cada módulo for ativado) ──
# META_APP_ID=
# META_APP_SECRET=
# WHATSAPP_CLOUD_TOKEN=
# PAYMENT_GATEWAY_KEY=

# ── Google (Meet/Calendar OAuth) — app OAuth GLOBAL da plataforma ──
# Vazio = integração indisponível (a Agenda segue com o campo manual de reunião).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=https://api.<dominio>/integrations/google/callback
