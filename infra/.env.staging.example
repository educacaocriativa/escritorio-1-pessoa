# ============================================================================
# STAGING — espelha a produção, mas com SEGREDOS e DOMÍNIO PRÓPRIOS (Story 3.1).
# ============================================================================
# Copie este arquivo para `infra/.env.prod` DENTRO do diretório do deploy de STAGING
# (NÃO do diretório de produção). O nome do arquivo em disco TEM que ser `.env.prod`
# porque é o que `docker-compose.prod.yml`/`docker-compose.traefik.yml` esperam
# (a chave `env_file: - .env.prod` é lida literalmente pelo Compose, não interpolada);
# é o CONTEÚDO que muda entre staging e produção, não o nome do arquivo.
#
#   cp .env.staging.example .env.prod   # (dentro do diretório/VPS de staging)
#
# Preferência: use uma VPS DEDICADA e barata para staging (isolamento físico total —
# redes/volumes/segredos separados da produção, AC3/IV3). Se o custo obrigar a
# compartilhar a MESMA VPS de produção, suba com um NOME DE PROJETO Compose distinto
# para isolar redes e volumes nomeados automaticamente:
#   docker compose -p e1p-staging -f docker-compose.prod.yml up -d --build
# Ver docs/HOSTINGER-DEPLOY.md §8.
#
# REGRA DE OURO: NUNCA reaproveite os valores de produção aqui. Staging tem os SEUS
# próprios segredos e o SEU próprio banco — jamais aponta para o banco/credenciais reais.

# Domínio de staging (subdomínio próprio apontando pro IP da VPS de staging).
DOMAIN=staging.seudominio.com

# Postgres — senhas fortes E PRÓPRIAS de staging (ex.: `openssl rand -base64 32`).
POSTGRES_ROOT_PASSWORD=
APP_DB_PASSWORD=

# Auth — string aleatória >= 32 chars E PRÓPRIA (ex.: `openssl rand -hex 32`).
# ENVIRONMENT=production faz o staging espelhar 100% o comportamento de produção
# (mesmo guard de segredos fortes; forgot_password não vaza dev_reset_token). A
# separação real staging/produção NÃO vem de ENVIRONMENT, e sim do domínio/host,
# deste .env com conteúdo próprio, e da flag SEED_SYNTHETIC_DATA abaixo. Ver Story 3.1.
JWT_SECRET=

# IA (obrigatório — o guard de produção recusa subir sem isso).
ANTHROPIC_API_KEY=

# Super Admin (Master) semeado no primeiro boot — senha PRÓPRIA de staging (guard recusa default).
SUPER_ADMIN_EMAIL=admin@staging.seudominio.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Administrador e1p (staging)

# App
ROOT_DOMAIN=staging.seudominio.com
FRONTEND_URL=https://staging.seudominio.com

# Integrações (vazio = stub/log; em staging podem ficar vazias — nada quebra).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
SMTP_HOST=
GATEWAY_WEBHOOK_SECRET=

# Seed de dados sintéticos — LIGADO em staging: cria um tenant de demonstração
# (slug "staging-demo") + usuário owner + registros mínimos (1 cliente CRM, 1 evento
# de Agenda, 1 cobrança em Contas a Receber) para o smoke test da esteira de deploy.
# Idempotente e independente de ENVIRONMENT (ver app/seed_staging.py). NUNCA defina
# isto como true em produção real.
SEED_SYNTHETIC_DATA=true
