# Copie para infra/.env.prod e preencha. NUNCA commitar o .env.prod real (já deve estar
# no .gitignore junto dos outros .env).

# Domínio público apontando pro IP da VPS (usado pelo Caddy p/ emitir TLS Let's Encrypt).
DOMAIN=app.seudominio.com

# Postgres — senhas fortes (ex.: `openssl rand -base64 32`).
POSTGRES_ROOT_PASSWORD=
APP_DB_PASSWORD=

# Auth — string aleatória >= 32 chars (ex.: `openssl rand -hex 32`). Guard de produção
# recusa subir com o valor default ou < 32 chars (ver app/config.py).
JWT_SECRET=

# IA (obrigatório em produção — guard recusa subir sem isso).
ANTHROPIC_API_KEY=

# Super Admin (Master) semeado no primeiro boot. Troque a senha default (guard recusa).
SUPER_ADMIN_EMAIL=admin@seudominio.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Administrador e1p

# App
ROOT_DOMAIN=seudominio.com
FRONTEND_URL=https://app.seudominio.com

# Integrações (vazio = stub/log; preencher quando conectar de verdade)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
SMTP_HOST=
GATEWAY_WEBHOOK_SECRET=

# Seed de dados sintéticos — SÓ para o ambiente de STAGING (Story 3.1). Em PRODUÇÃO
# deixe VAZIO/false: com isto vazio o boot NÃO cria nenhum tenant/dado de demonstração
# (`python -m app.seed_staging` vira no-op). Para o ambiente de staging, use o
# .env.staging.example (que define SEED_SYNTHETIC_DATA=true). Ver docs/HOSTINGER-DEPLOY.md §8.
SEED_SYNTHETIC_DATA=

# Backup offsite (Story 3.3 — ver docs/RUNBOOK-BACKUP-RESTORE.md).
# Consumido pelos scripts de HOST infra/scripts/backup.sh e restore.sh (não pela API).
# A config do rclone (remote `e1p-offsite` + credenciais do provedor S3-compatível) é
# feita FORA do repo, via `rclone config` na VPS — NUNCA commitar credenciais aqui.
# BACKUP_S3_BUCKET: path no remote rclone (ex.: meu-bucket/e1p). Vazio = pula o offsite.
BACKUP_S3_BUCKET=
# Retenção LOCAL (dias): backup.sh apaga dumps locais mais antigos que isso.
BACKUP_RETENTION_DAYS_LOCAL=7
# Retenção REMOTA (dias): aplicada via LIFECYCLE RULE do bucket no provedor (fora do
# script) — apenas documental aqui; ver o runbook p/ como configurar no provedor.
BACKUP_RETENTION_DAYS_REMOTE=30
