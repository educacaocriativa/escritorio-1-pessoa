# Copie para infra/.env.prod e preencha. NUNCA commitar o .env.prod real (já deve estar
# no .gitignore junto dos outros .env).

# Domínio público apontando pro IP da VPS (usado pelo Caddy p/ emitir TLS Let's Encrypt).
DOMAIN=app.seudominio.com

# Postgres — senhas fortes (ex.: `openssl rand -base64 32`).
POSTGRES_ROOT_PASSWORD=
APP_DB_PASSWORD=

# Auth — string aleatória >= 32 chars (ex.: `openssl rand -hex 32`). Guard de produção
# recusa subir com o valor default ou < 32 chars (ver app/config.py).
JWT_SECRET=

# IA (obrigatório em produção — guard recusa subir sem isso).
ANTHROPIC_API_KEY=

# Super Admin (Master) semeado no primeiro boot. Troque a senha default (guard recusa).
SUPER_ADMIN_EMAIL=admin@seudominio.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Administrador e1p

# App
ROOT_DOMAIN=seudominio.com
FRONTEND_URL=https://app.seudominio.com

# Worker durável (serviço `worker`): intervalo entre sweeps do funil + fila (segundos).
# Opcional — default 60s (ver app/config.py::worker_tick_interval_seconds).
# WORKER_TICK_INTERVAL_SECONDS=60

# Wildcard de subdomínio por tenant (Story 4.4) — TLS `*.${ROOT_DOMAIN}` via desafio DNS-01.
# Token da Cloudflare com escopo MÍNIMO: Zone.DNS -> Edit na zona do ROOT_DOMAIN (menor
# privilégio). Necessário só p/ o bloco wildcard do Caddyfile (o domínio único usa HTTP-01,
# não precisa dele). Vazio = wildcard não emite o certificado (domínio único segue normal).
# Pré-requisito: DNS de ${ROOT_DOMAIN} gerido pela Cloudflare (ver docs/HOSTINGER-DEPLOY.md §8).
CLOUDFLARE_API_TOKEN=

# Integrações (vazio = stub/log; preencher quando conectar de verdade)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
SMTP_HOST=
GATEWAY_WEBHOOK_SECRET=
